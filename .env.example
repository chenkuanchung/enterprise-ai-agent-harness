# ==========================================
# 核心應用設定 (Core Settings)
# ==========================================
APP_NAME="Enterprise AI Agent Harness"
APP_ENV="development"
API_V1_STR="/v1"
LOG_LEVEL="DEBUG"
SECRET_KEY="your-super-secret-jwt-key"  # 供 PyJWT 加密解密使用 (實務上請用 openssl rand -hex 32 生成)

# ==========================================
# 數據面：資料庫與快取 (Database & Caching)
# ==========================================
# PostgreSQL 配置 (對應 Docker Compose)
POSTGRES_USER="harness_user"
POSTGRES_PASSWORD="harness_password"
POSTGRES_DB="harness_db"
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"

# 供 SQLAlchemy 與 asyncpg 使用的非同步連線字串
DATABASE_URL="postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

# Redis (供 RedisVL 語意快取 Semantic Caching 使用)
REDIS_URL="redis://localhost:6379/0"

# ==========================================
# AI / LLM 供應商 (Model Credentials)
# ==========================================
# 主力模型 (Gemini API)
GOOGLE_API_KEY="your-gemini-api-key-here"

# 本地備援/Guardrails 模型 (對應 docker-compose 的 ollama 服務)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3" # 或其他預計使用的 Guardrail 模型

# ==========================================
# 監控與可觀測性 (Observability)
# ==========================================
# Langfuse 憑證
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_HOST="https://cloud.langfuse.com"