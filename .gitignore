# ==============================================================================
# 1. 核心資安與環境變數 (絕對禁止上傳)
# ==============================================================================
.env
.env.local
.env.*.local
*.pem
*.key

# ==============================================================================
# 2. Python 虛擬環境與編譯快取
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.venv/
venv/
ENV/
env/

# ==============================================================================
# 3. 專案特有之本地向量資料庫與大容量快取 (避免版控肥大)
# ==============================================================================
chroma_data/
redis_data/
.chunks_cache/

# ==============================================================================
# 4. 現代 Python 工具鏈與測試快取 (Ruff, MyPy, Pytest)
# ==============================================================================
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# ==============================================================================
# 5. IDEs 與編輯器設定 (支援跨團隊開發環境)
# ==============================================================================
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# ==============================================================================
# 6. 作業系統層級雜訊 (防止 Windows/Mac 產生衝突檔)
# ==============================================================================
# Windows
Thumbs.db
Ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# ==============================================================================
# 7. 容器化與日誌
# ==============================================================================
.docker/
*.log
logs/